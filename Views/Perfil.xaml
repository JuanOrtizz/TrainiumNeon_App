<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrainiumNeon.Views.Perfil"
             >

    <Grid
        Padding="30,40"
        RowDefinitions="Auto,Auto"
        RowSpacing="50"
        BackgroundColor="#1A2745"
        >

        <Grid
            Grid.Row="0"
            RowDefinitions="*,*,*,*"
            RowSpacing="30"
            >

            <Label
                Grid.Row="0"
                Text="Tu Perfil"
                TextColor="White"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                />

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="1"
                HeightRequest="50"
                BackgroundColor="White"
                Padding="5, 0"
                >

                <Entry
                    Text="Nombre del usuario"
                    Placeholder="Coloca tu nombre"
                    PlaceholderColor="Black"
                    FontSize="16"
                    MaxLength="100"
                    BackgroundColor="Transparent"
                    />

            </Border>

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="2"
                HeightRequest="50"
                BackgroundColor="White"
                Padding="5, 0"
                >

                <Entry
                    Text="email@usuario.com"
                    PlaceholderColor="Black"
                    FontSize="16"
                    MaxLength="254"
                    BackgroundColor="Transparent"
                    />

            </Border>

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="3"
                >

                <Button
                    Text="Cambiar Datos"
                    FontAttributes="Bold"
                    BackgroundColor="#C4EEF2"
                    FontSize="18"
                    HeightRequest="50"
                    TextColor="Black"
                    />

            </Border>

        </Grid>

        <Grid
            Grid.Row="1"
            RowDefinitions="*,*,*,*"
            RowSpacing="30"
            >

            <Label
                Text="Cambia tu Contraseña"
                Grid.Row="0"
                FontSize="20"
                TextColor="White"
                FontAttributes="Bold"
                HorizontalOptions="Start"
                VerticalOptions="Center"/>

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="1"
                BackgroundColor="White"
                HeightRequest="50"
                Padding="5, 0"
                >

                <Entry
                    Placeholder="Nueva Contraseña"
                    PlaceholderColor="Black"
                    FontSize="16"
                    IsPassword="True"
                    MaxLength="25"
                    BackgroundColor="Transparent"
                    />

            </Border>

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="2"
                BackgroundColor="White"
                HeightRequest="50"
                Padding="5, 0"
                >

                <Entry
                    Placeholder="Confirmar Nueva Contraseña"
                    PlaceholderColor="Black"
                    FontSize="16"
                    IsPassword="True"
                    MaxLength="25"
                    BackgroundColor="Transparent"
                    />

            </Border>

            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="0"
                Grid.Row="3"
                >

                <Button
                    Text="Cambiar Contraseña"
                    FontAttributes="Bold"
                    BackgroundColor="#C4EEF2"
                    FontSize="18"
                    HeightRequest="50"
                    TextColor="Black"
                    />

            </Border>
            
        </Grid>

    </Grid>
    
</ContentPage>