<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrainiumNeon.Views.Perfil"
             >
    <ScrollView>
        <Grid>
            <Grid
            Padding="30,40"
            RowDefinitions="Auto,Auto, Auto"
            RowSpacing="30"
            BackgroundColor="#1A2745"
            >

                <Grid
                    Grid.Row="0"
                    RowDefinitions="Auto, Auto"
                    ColumnDefinitions="*, Auto"
                    RowSpacing="20">


                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="Tu Perfil"
                        TextColor="White"
                        FontSize="24"
                        FontAttributes="Bold"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        />

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Stroke="#00F0FF"
                        StrokeShape="RoundRectangle 5"
                        StrokeThickness="2"
                        Padding="10,5"
                        HorizontalOptions="Fill"
                        VerticalOptions="Center"
                        >

                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="15">
                            
                            <Label
                                Grid.Column="0"
                                Text="Permitir notificaciones"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                />

                            <Switch
                                Grid.Column="1"
                                IsToggled="{Binding NotificacionesActivas, Mode=TwoWay}"
                                OnColor="#00CDDB"
                                Scale="1.2"
                                ThumbColor="White"
                                HorizontalOptions="End"
                                VerticalOptions="Center"/>
                            
                        </Grid>

                    </Border>

                    

                </Grid>
                
                <Grid
                Grid.Row="1"
                RowDefinitions="*,*,*,*"
                RowSpacing="20"
                >

                    <Label
                    Grid.Row="0"
                    Text="Tus datos"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    />

                    <VerticalStackLayout
                    Spacing="5"
                    Grid.Row="1"
                    >

                        <Border
                        StrokeShape="RoundRectangle 5"
                        StrokeThickness="2"
                        Stroke="Gray"
                        HeightRequest="50"
                        BackgroundColor="White"
                        Padding="5, 0"
                        >

                            <Border.Triggers>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding Source={x:Reference NombreEntry}, Path=IsFocused}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="#00F0FF" />
                                </DataTrigger>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding HayErrorEnNuevoNombre}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="Red" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Entry
                            x:Name="NombreEntry"
                            Placeholder="Coloca tu nuevo nombre"
                            PlaceholderColor="Black"
                            FontSize="16"
                            MaxLength="100"
                            BackgroundColor="Transparent"
                            Text="{Binding Nombre}"
                            TextColor="Black"
                            />

                        </Border>

                        <Label
                        Text="{Binding ErrorNuevoNombre}"
                        FontSize="14"
                        TextColor="Red"
                        IsVisible="{Binding HayErrorEnNuevoNombre}"
                        />

                    </VerticalStackLayout>

                    <VerticalStackLayout
                    Spacing="5"
                    Grid.Row="2"
                    >

                        <Border
                        StrokeShape="RoundRectangle 5"
                        StrokeThickness="2"
                        Stroke="Gray"
                        HeightRequest="50"
                        BackgroundColor="White"
                        Padding="5, 0"
                        >

                            <Border.Triggers>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding Source={x:Reference EmailEntry}, Path=IsFocused}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="#00F0FF" />
                                </DataTrigger>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding HayErrorEnNuevoEmail}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="Red" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Entry
                                x:Name="EmailEntry"
                                PlaceholderColor="Black"
                                FontSize="16"
                                MaxLength="254"
                                Placeholder="Coloca tu nuevo email"
                                BackgroundColor="Transparent"
                                Text="{Binding Email}"
                                TextColor="Black"
                                Keyboard="Email"                                
                                />

                        </Border>

                        <Label
                        Text="{Binding ErrorNuevoEmail}"
                        FontSize="14"
                        TextColor="Red"
                        IsVisible="{Binding HayErrorEnNuevoEmail}"
                        />

                    </VerticalStackLayout>

                    <Button
                    x:Name="BtnCambiarDatos"
                    CornerRadius="5"
                    Grid.Row="3"
                    Text="Cambiar Datos"
                    FontAttributes="Bold"
                    BackgroundColor="#00CDDB"
                    FontSize="18"
                    HeightRequest="50"
                    TextColor="White"
                    Command="{Binding CambiarDatosPersonalesCommand}"
                    IsEnabled="{Binding PuedeActualizar}"
                    >
                        <Button.Triggers>
                            <DataTrigger
                            TargetType="Button"
                            Binding="{Binding PuedeActualizar}"
                            Value="False">
                                <Setter Property="BackgroundColor" Value="#8A8A8A" />
                                <Setter Property="TextColor" Value="#E0E0E0" />
                            </DataTrigger>

                            <DataTrigger
                            TargetType="Button"
                            Binding="{Binding PuedeActualizar}"
                            Value="True">
                                <Setter Property="BackgroundColor" Value="#00CDDB" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                </Grid>

                <Grid
                Grid.Row="2"
                RowDefinitions="*,*,*,*"
                RowSpacing="20"
                >

                    <Label
                    Text="Cambia tu Contraseña"
                    Grid.Row="0"
                    FontSize="20"
                    TextColor="White"
                    FontAttributes="Bold"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"/>

                    <VerticalStackLayout
                    Spacing="5"
                    Grid.Row="1"
                    >

                        <Border
                        StrokeShape="RoundRectangle 5"
                        StrokeThickness="2"
                        Stroke="Gray"
                        >

                            <Border.Triggers>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding Source={x:Reference NuevaContraseniaEntry}, Path=IsFocused}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="#00F0FF" />
                                </DataTrigger>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding HayErrorEnNuevaContrasenia}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="Red" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid
                            Padding="10"
                            RowDefinitions="*"
                            ColumnDefinitions="9*, 1*"
                            RowSpacing="200"
                            BackgroundColor="#f0f0f0"
                            VerticalOptions="Center"
                            HorizontalOptions="Fill"
                            HeightRequest="50"
                            >

                                <Entry
                                x:Name="NuevaContraseniaEntry"
                                Grid.Column="0"
                                Placeholder="Confirmar Contraseña"
                                PlaceholderColor="Black"
                                FontSize="16"
                                IsPassword="{Binding NuevaContraseniaOculta}"
                                MaxLength="25"
                                HeightRequest="50"
                                BackgroundColor="Transparent"
                                Text="{Binding NuevaContrasenia}"
                                TextColor="Black"
                                />

                                <Image
                                Grid.Column="2"
                                Source="{Binding IconoNuevaContrasenia}"
                                WidthRequest="25"
                                HeightRequest="25"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                >
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding CambiarEstadoNuevaContraseniaCommand}" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>

                        </Border>

                        <Label
                        Text="{Binding ErrorNuevaContrasenia}"
                        FontSize="14"
                        TextColor="Red"
                        IsVisible="{Binding HayErrorEnNuevaContrasenia}"
                        />

                    </VerticalStackLayout>

                    <VerticalStackLayout
                    Spacing="5"
                    Grid.Row="2"
                    >

                        <Border
                        StrokeShape="RoundRectangle 5"
                        StrokeThickness="2"
                        Stroke="Gray"
                        >

                            <Border.Triggers>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding Source={x:Reference ConfirmarNuevaContraseniaEntry}, Path=IsFocused}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="#00F0FF" />
                                </DataTrigger>
                                <DataTrigger
                                    TargetType="Border"
                                    Binding="{Binding HayErrorEnConfirmarNuevaContrasenia}"
                                    Value="True"
                                    >
                                    <Setter Property="Stroke" Value="Red" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid
                            Padding="10"
                            RowDefinitions="*"
                            ColumnDefinitions="9*, 1*"
                            RowSpacing="200"
                            BackgroundColor="#f0f0f0"
                            VerticalOptions="Center"
                            HorizontalOptions="Fill"
                            HeightRequest="50"
                            >

                                <Entry
                                x:Name="ConfirmarNuevaContraseniaEntry"
                                Grid.Column="0"
                                Placeholder="Confirmar Nueva Contraseña"
                                PlaceholderColor="Black"
                                FontSize="16"
                                IsPassword="{Binding ConfirmarNuevaContraseniaOculta}"
                                MaxLength="25"
                                HeightRequest="50"
                                BackgroundColor="Transparent"
                                Text="{Binding ConfirmarNuevaContrasenia}"
                                TextColor="Black"
                                />

                                <Image
                                    Grid.Column="2"
                                    Source="{Binding IconoConfirmarNuevaContrasenia}"
                                    WidthRequest="25"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    >
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding CambiarEstadoConfirmarNuevaContraseniaCommand}" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>

                        </Border>

                        <Label
                        Text="{Binding ErrorConfirmarNuevaContrasenia}"
                        FontSize="14"
                        TextColor="Red"
                        IsVisible="{Binding HayErrorEnConfirmarNuevaContrasenia}"
                        />

                    </VerticalStackLayout>

                    <VerticalStackLayout
                    Grid.Row="3"
                    Spacing="20"
                    >

                        <Button
                        CornerRadius="5"
                        Text="Cambiar Contraseña"
                        FontAttributes="Bold"
                        BackgroundColor="#00CDDB"
                        FontSize="18"
                        HeightRequest="50"
                        TextColor="White"
                        Command="{Binding CambiarContraseniaCommand}"
                        />

                        <Button
                        CornerRadius="5"
                        Text="Cerrar Sesión"
                        FontAttributes="Bold"
                        BackgroundColor="DarkRed"
                        FontSize="18"
                        HeightRequest="50"
                        TextColor="White"
                        Command="{Binding CerrarSesionCommand}"
                        />
                    </VerticalStackLayout>

                </Grid>

            </Grid>

            <Grid
            IsVisible="{Binding IsBusy}"
            BackgroundColor="#40000000"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            ZIndex="999">

                <ActivityIndicator
                IsRunning="True"
                Scale="1.5"
                Color="#00F0FF"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
            </Grid>

        </Grid>
    </ScrollView>

</ContentPage>