<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TrainiumNeon.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TrainiumNeon.Views"
    Title="TrainiumNeon"
    NavBarIsVisible="False"
    TabBarBackgroundColor="Black"
    TabBarForegroundColor="#00A7B3"
    TabBarUnselectedColor="White"
    ForegroundColor="White"
    BackgroundColor="#1A2745"
    NavBarHasShadow="False"
    >

    <ShellContent
        Route="Login"
        ContentTemplate="{DataTemplate local:MainPage}"
        Shell.NavBarIsVisible="False"
        Shell.TabBarIsVisible="False" />

    <ShellContent
        Route="Registro"
        ContentTemplate="{DataTemplate local:Registro}"
        Shell.NavBarIsVisible="False"
        Shell.TabBarIsVisible="False" />

    <TabBar>
        <ShellContent Route="MenuPrincipal" Title="Inicio" Icon="inicio.png" ContentTemplate="{DataTemplate local:MenuPrincipal}" />
        <ShellContent Route="Estadisticas" Title="Estadisticas" Icon="estadisticas.png" ContentTemplate="{DataTemplate local:Estadisticas}" />
        <ShellContent Route="Rutinas" Title="Rutinas" Icon="rutinas.png" ContentTemplate="{DataTemplate local:Rutinas}" />
        <ShellContent Route="Perfil" Title="Perfil" Icon="perfil.png" ContentTemplate="{DataTemplate local:Perfil}" />
    </TabBar>

</Shell>
